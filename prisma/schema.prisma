datasource db {
  provider = "mysql"
   url    = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id    Int    @id @default(autoincrement())
  name  String
  email String
  password  String?
  ssoId  String?  @unique
  createdAt DateTime @default(now())
  verificationToken String?
  isActive Boolean?
  setupTokenExpires BigInt? 
  sessions  Session[]
}

model Session {
  id           String   @id @default(uuid())
  userId       Int
  refreshToken String
  userAgent    String?
  ip           String?
  createdAt    DateTime @default(now())
  expiredAt    DateTime
  user User @relation(fields: [userId], references: [id])
}






